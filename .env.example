# Copy this file to .env and fill in your keys
# Never commit .env to git

# GitHub Models (required for AI responses)
GITHUB_TOKEN=your_github_token_here

# Google Gemini (optional fallback AI)
GEMINI_API_KEY=your_gemini_key_here

# Bluesminds coding AI (optional)
BLUESMINDS_KEY=your_bluesminds_key_here

# ElevenLabs TTS (optional, for voice responses)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Flask session secret (auto-generated if not set)
# SECRET_KEY=generate_with_python_-c_"import_secrets;print(secrets.token_hex(32))"
